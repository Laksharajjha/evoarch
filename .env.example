# Use Gemini automatically when this key is present.
GEMINI_API_KEY=
# Optional: use direct OpenAI instead when no Gemini key is configured.
OPENAI_API_KEY=
# Optional: override the direct OpenAI model.
EVOARCH_OPENAI_MODEL=gpt-5.6-terra
# Optional: gemini or openai. Auto-detected from configured keys when omitted.
EVOARCH_AI_PROVIDER=
# Optional: override the Gemini model used for model-authored outputs.
EVOARCH_GEMINI_MODEL=gemini-3.1-flash-lite
# Optional: model-authored fallback used only if intent schema validation fails.
EVOARCH_GEMINI_INTENT_FALLBACK_MODEL=gemini-3.1-flash-lite
# Optional: Gemini fallback used after deployment validation fails.
EVOARCH_GEMINI_DEPLOYMENT_FALLBACK_MODEL=gemini-3.1-flash-lite
# Optional: comma-separated deployment models to race in parallel. When blank,
# EvoArch races the primary model with the fallback model above.
EVOARCH_GEMINI_DEPLOYMENT_MODELS=
# Dashboard access code. Replace this default before sharing the control plane.
ACCESS_CODE=EVO-JUDGE-26
